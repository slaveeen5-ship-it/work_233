SYSTEM_JITTER = 0.05 ns;

# Clock
# Location Constraints
# System clock 100 MHz;
NET sys_clk_p               LOC = K13 | DIFF_TERM = TRUE | IOSTANDARD = LVDS_25; # SYS_CLK0_P
NET sys_clk_n               LOC = K12 | DIFF_TERM = TRUE | IOSTANDARD = LVDS_25; # SYS_CLK0_N
# # REF clock 200 MHz;
# NET ref_clk_p               LOC = D11 | DIFF_TERM = TRUE | IOSTANDARD = LVDS_25; # CLK_REF0_P
# NET ref_clk_n               LOC = E11 | DIFF_TERM = TRUE | IOSTANDARD = LVDS_25; # CLK_REF0_N
# GTP-clock for RIO 153.6 MHz;
NET mgt_clk_p               LOC = P6; # SI5338_SERDES_P
NET mgt_clk_n               LOC = P5; # SI5338_SERDES_N
# PCIe clock 125 MHz;
NET pcie_clk_p              LOC = AB6; # SI5338_PCIE0_P
NET pcie_clk_n              LOC = AB5; # SI5338_PCIE0_N

# # External Timing Name Net
NET "sys_clk_p"         TNM_NET = "TNM_ext_clk";
NET "mgt_clk_p"         TNM_NET = "TNM_mgt_clk";
# NET "ref_clk_p"         TNM_NET = "TNM_ref_clk";
NET "pcie_clk_p"        TNM_NET = "TNM_pcie_clk";

# Internal Timing Name Net
# NET "clock_block_i/sys_clk_out"                                TNM_NET = "TNM_sys_clk";
#NET "clock_block_i/math_clk_out"                               TNM_NET = "TNM_math_clk";
# NET "qdr_block_i/mig_qdr_i/u_user_top/*/clk_rd*"            TNM_NET = "TNM_qdr_clk";
# NET "*/gth_connect_fifo_0_inst/*/gt0_txoutclk_i"            TNM_NET = "TNM_mgt_clk_1";
# NET "*/gth_connect_fifo_2_inst/*/gt0_txoutclk_i"            TNM_NET = "TNM_mgt_clk_2";
# NET "*/make4Lanes.pcieCore/pcie_clocking_i/clk_125"         TNM_NET = "TNM_pcie_125";
# NET "*/make4Lanes.pcieCore/TxOutClk_bufg"                   TNM_NET = "TNM_pcie_out";

# Timing Specifications
TIMESPEC "TS_ext_clk"   = PERIOD "TNM_ext_clk"   10.0 ns HIGH 50% PRIORITY 1;
TIMESPEC "TS_mgt_clk"   = PERIOD "TNM_mgt_clk"   6.51 ns HIGH 50% PRIORITY 100;
# TIMESPEC "TS_ref_clk"   = PERIOD "TNM_ref_clk"   5.0 ns  HIGH 50% PRIORITY 100;
TIMESPEC "TS_pcie_clk"  = PERIOD "TNM_pcie_clk"  8.0 ns  HIGH 50% PRIORITY 100;
# TIMESPEC "TS_mgt_clk_1" = PERIOD "TNM_mgt_clk_1" 3.255   HIGH 50% PRIORITY 200;
# TIMESPEC "TS_mgt_clk_2" = PERIOD "TNM_mgt_clk_2" 3.255   HIGH 50% PRIORITY 200;
# TIMESPEC "TS_qdr_clk"   = PERIOD "TNM_qdr_clk"   10 ns   HIGH 50% PRIORITY 200;
# TIMESPEC "TS_pcie_125"  = PERIOD "TNM_pcie_125"  8.0 ns  HIGH 50% PRIORITY 100;
# TIMESPEC "TS_pcie_out"  = PERIOD "TNM_pcie_out"  8.0 ns  HIGH 50% PRIORITY 10;

# TIMESPEC "TS_exception1" = FROM "TNM_sys_clk"  TO "TNM_math_clk" TIG;
# TIMESPEC "TS_exception2" = FROM "TNM_math_clk" TO "TNM_sys_clk"  TIG;
# TIMESPEC "TS_exception3" = FROM "TNM_sys_clk"  TO "TNM_pcie_125" TIG;
# TIMESPEC "TS_exception4" = FROM "TNM_pcie_125" TO "TNM_sys_clk"  TIG;
# TIMESPEC "TS_exception5" = FROM "TNM_sys_clk"  TO "TNM_qdr_clk"  TIG;

