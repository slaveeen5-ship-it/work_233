 NET pci_exp_txn(0)      LOC = AP2; # IPASS_TX0_N

 NET pci_exp_rxp(1)      LOC = AM5; # IPASS_RX1_P
 NET pci_exp_rxn(1)      LOC = AM6; # IPASS_RX1_N
 NET pci_exp_txp(1)      LOC = AN3; # IPASS_TX1_P
 NET pci_exp_txn(1)      LOC = AN4; # IPASS_TX1_N

 NET pci_exp_rxp(2)      LOC = AL3; # IPASS_RX2_P
 NET pci_exp_rxn(2)      LOC = AL4; # IPASS_RX2_N
 NET pci_exp_txp(2)      LOC = AM1; # IPASS_TX2_P
 NET pci_exp_txn(2)      LOC = AM2; # IPASS_TX2_N

 NET pci_exp_rxp(3)      LOC = AJ3; # IPASS_RX3_P
 NET pci_exp_rxn(3)      LOC = AJ4; # IPASS_RX3_N
 NET pci_exp_txp(3)      LOC = AK1; # IPASS_TX3_P
 NET pci_exp_txn(3)      LOC = AK2; # IPASS_TX3_N

